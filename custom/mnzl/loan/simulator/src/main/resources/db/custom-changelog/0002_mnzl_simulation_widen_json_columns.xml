<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <!--
      A 12-installment lifecycle snapshot can exceed the 64KB TEXT limit on MariaDB/MySQL once the
      schedule, transactions, and per-action snapshot list are serialized. Widen result_json and
      scenario_json to LONGTEXT so realistic simulations don't fail the JDBC update with
      "Data too long for column". error_message stays TEXT — it only ever holds a short stack-line.
    -->
    <changeSet author="mnzl" id="1">
        <modifyDataType tableName="m_mnzl_simulation" columnName="result_json" newDataType="LONGTEXT"/>
    </changeSet>
    <changeSet author="mnzl" id="2">
        <modifyDataType tableName="m_mnzl_simulation" columnName="scenario_json" newDataType="LONGTEXT"/>
    </changeSet>
</databaseChangeLog>
